#!/usr/bin/env bash
set -euo pipefail

REMOTE_USER="david"
REMOTE_HOST="192.168.0.112"
REMOTE_PORT="8080"

AUDIO_DEVICE=":1"
CHUNK_SECONDS="3"

WHISPER_LANG="auto"
TRANSLATE="false"

GLOBAL_OFFSET_MS=0
_TS_SRT_PATTERN='^([0-9]{2}:[0-9]{2}:[0-9]{2},[0-9]{3})[[:space:]]+-->[[:space:]]+([0-9]{2}:[0-9]{2}:[0-9]{2},[0-9]{3})$'

mkdir -p "$HOME/whisper"

usage() {
  cat <<EOF
Usage:
  $0 [-l LANG] [-t] [--clean]

Options:
  -l LANG     Language for Whisper request. Examples: en, es, auto
              Default: auto
  -t          Translate to English
  --clean     Delete previous wav chunks under ~/whisper and exit

Examples:
  $0
  $0 -l es
  $0 -l en
  $0 -l es -t
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --clean)
      echo "Cleaning all .wav files from ~/whisper..."
      find "$HOME/whisper" -name "*.wav" -delete 2>/dev/null || true
      echo "Done."
      exit 0
      ;;
    -l)
      shift
      if [[ $# -eq 0 ]]; then
        echo "error: -l requires a value"
        usage
        exit 1
      fi
      WHISPER_LANG="$1"
      shift
      ;;
    -t)
      TRANSLATE="true"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1"
      usage
      exit 1
      ;;
  esac
done

SESSION_TS="$(date +%Y%m%d_%H%M%S)"
WORKDIR="$HOME/whisper/${SESSION_TS}"
OUTPUT_DIR="$HOME/whisper/outputs/${SESSION_TS}"
CHUNK_DIR="$WORKDIR"
STOP_FLAG="$WORKDIR/.stop"
mkdir -p "$WORKDIR"
mkdir -p "$OUTPUT_DIR"

echo "Audio directory: $WORKDIR"

REC_PID=""
WATCH_PID=""
CLEANED=0

cleanup() {
  if [ "$CLEANED" -eq 1 ]; then
    return
  fi
  CLEANED=1

  echo
  echo "Stopping live-whisper..."

  if [ -n "${REC_PID:-}" ] && kill -0 "$REC_PID" 2>/dev/null; then
    kill -INT "$REC_PID" 2>/dev/null || true
    wait "$REC_PID" 2>/dev/null || true
  fi

  touch "$STOP_FLAG" 2>/dev/null || true

  if [ -n "${WATCH_PID:-}" ] && kill -0 "$WATCH_PID" 2>/dev/null; then
    wait "$WATCH_PID" 2>/dev/null || true
  fi

  echo "live-whisper stopped cleanly"
}

trap cleanup INT TERM EXIT

echo "Starting remote whisper-server on ${REMOTE_HOST}..."
ssh "${REMOTE_USER}@${REMOTE_HOST}" "~/bin/start_whisper_server.sh ${REMOTE_PORT}"

echo "Waiting for server to become reachable..."
until curl -s "http://${REMOTE_HOST}:${REMOTE_PORT}/" >/dev/null 2>&1; do
  sleep 1
done

echo
echo "Listening from mic..."
echo "Press ENTER or Ctrl+C to stop."
echo "Language : ${WHISPER_LANG}"
echo "Translate: ${TRANSLATE}"
echo

ffmpeg -loglevel info \
  -f avfoundation -use_wallclock_as_timestamps 1 -i "${AUDIO_DEVICE}" \
  -ac 1 -ar 16000 -c:a pcm_s16le \
  -f segment -segment_time "${CHUNK_SECONDS}" -segment_format wav \
  "${CHUNK_DIR}/chunk_%06d.wav" \
  >"${WORKDIR}/ffmpeg.out.log" 2>"${WORKDIR}/ffmpeg.err.log" &
REC_PID=$!

srt_to_ms() {
  local ts="$1"
  local hh mm ss mmm
  IFS=':,' read -r hh mm ss mmm <<< "$ts"
  echo $((10#$hh * 3600000 + 10#$mm * 60000 + 10#$ss * 1000 + 10#$mmm))
}

ms_to_srt() {
  local total_ms="$1"
  local hh=$(( total_ms / 3600000 ))
  local rem=$(( total_ms % 3600000 ))
  local mm=$(( rem / 60000 ))
  rem=$(( rem % 60000 ))
  local ss=$(( rem / 1000 ))
  local mmm=$(( rem % 1000 ))
  printf "%02d:%02d:%02d,%03d" "$hh" "$mm" "$ss" "$mmm"
}

process_chunk() {
  local file="$1"

  local resp
  resp="$(curl -sS -X POST "http://${REMOTE_HOST}:${REMOTE_PORT}/inference" \
    -F "file=@${file}" \
    -F "response_format=srt" \
    -F "language=${WHISPER_LANG}" \
    -F "translate=${TRANSLATE}" \
    -F "beam_size=5" \
    -F "best_of=5" \
    -F "max_context=512" \
    -F "temperature=0.0" \
    -F "temperature_inc=0.0" \
    -F "suppress_nst=true" \
    -F "no_speech_thold=0.60" \
    -F "entropy_thold=2.40" \
    -F "logprob_thold=-1.00")"

  local current_ts=""
  local current_text=""
  local max_local_end_ms=0

  while IFS= read -r line; do
    if [[ "$line" =~ ^[0-9]+$ ]]; then
      continue
    fi

    if [[ "$line" =~ $_TS_SRT_PATTERN ]]; then
      local start_local="${BASH_REMATCH[1]}"
      local end_local="${BASH_REMATCH[2]}"
      local start_local_ms end_local_ms
      start_local_ms="$(srt_to_ms "$start_local")"
      end_local_ms="$(srt_to_ms "$end_local")"

      if (( end_local_ms > max_local_end_ms )); then
        max_local_end_ms=$end_local_ms
      fi

      local start_abs_ms=$((GLOBAL_OFFSET_MS + start_local_ms))
      local end_abs_ms=$((GLOBAL_OFFSET_MS + end_local_ms))
      current_ts="$(ms_to_srt "$start_abs_ms") --> $(ms_to_srt "$end_abs_ms")"
      continue
    fi

    if [[ -z "$line" ]]; then
      if [[ -n "$current_ts" && -n "$current_text" ]]; then
        local out_line="[${current_ts//,/.}]   ${current_text}"
        printf '%s\n' "$out_line"
        printf '%s\n' "$out_line" >> "${OUTPUT_DIR}/transcript_with_timestamps.txt"
        printf '%s' "$current_text " >> "${OUTPUT_DIR}/transcript.txt"
        current_ts=""
        current_text=""
      fi
      continue
    fi

    if [[ -z "$current_text" ]]; then
      current_text="$line"
    else
      current_text="$current_text $line"
    fi
  done <<< "$resp"

  if [[ -n "$current_ts" && -n "$current_text" ]]; then
    local out_line="[${current_ts//,/.}]   ${current_text}"
    printf '%s\n' "$out_line"
    printf '%s\n' "$out_line" >> "${OUTPUT_DIR}/transcript_with_timestamps.txt"
    printf '%s' "$current_text " >> "${OUTPUT_DIR}/transcript.txt"
  fi

  if (( max_local_end_ms > 0 )); then
    GLOBAL_OFFSET_MS=$((GLOBAL_OFFSET_MS + max_local_end_ms))
  else
    GLOBAL_OFFSET_MS=$((GLOBAL_OFFSET_MS + CHUNK_SECONDS * 1000))
  fi
}

watch_chunks() {
  trap '' INT

  local next_idx=0

  while true; do
    local file
    local next_file

    file=$(printf "%s/chunk_%06d.wav" "$CHUNK_DIR" "$next_idx")
    next_file=$(printf "%s/chunk_%06d.wav" "$CHUNK_DIR" "$((next_idx + 1))")

    if [ -f "$file" ]; then
      # Process a chunk only after the following chunk exists,
      # or when stop has been requested and ffmpeg has ended.
      if [ -f "$next_file" ]; then
        process_chunk "$file"
        next_idx=$((next_idx + 1))
        continue
      fi

      if [ -f "$STOP_FLAG" ] && { [ -z "${REC_PID:-}" ] || ! kill -0 "$REC_PID" 2>/dev/null; }; then
        process_chunk "$file"
        next_idx=$((next_idx + 1))
        continue
      fi
    fi

    if [ -f "$STOP_FLAG" ] && { [ -z "${REC_PID:-}" ] || ! kill -0 "$REC_PID" 2>/dev/null; }; then
      if [ ! -f "$file" ]; then
        break
      fi
    fi

    sleep 0.2
  done
}

watch_chunks &
WATCH_PID=$!

read -r _

if kill -0 "$REC_PID" 2>/dev/null; then
  kill -INT "$REC_PID" 2>/dev/null || true
  wait "$REC_PID" 2>/dev/null || true
fi

touch "$STOP_FLAG"
wait "$WATCH_PID" 2>/dev/null || true

cleanup